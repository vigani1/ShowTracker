{
  "expo": {
    "name": "ShowTracker",
    "description": "Track shows, anime, and movies across web and mobile.",
    "slug": "showtracker",
    "scheme": "showtracker",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#0b0f1a",
    "primaryColor": "#ef4444",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "backgroundColor": "#0b0f1a"
    },
    "android": {
      "icon": "./assets/icon.png",
      "backgroundColor": "#0b0f1a",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#0b0f1a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "ShowTracker",
      "shortName": "ShowTracker",
      "description": "Track shows, anime, and movies across web and mobile.",
      "scope": "/",
      "themeColor": "#0b0f1a",
      "backgroundColor": "#0b0f1a",
      "display": "standalone",
      "startUrl": "/home",
      "barStyle": "black"
    }
  }
}
