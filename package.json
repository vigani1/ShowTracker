    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
