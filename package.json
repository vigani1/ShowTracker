{
  "name": "showtracker",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:web": "cross-env CI=false expo start --web",
    "start:web:clear": "cross-env CI=false expo start --web --clear",
    "start:clear": "expo start --clear",
    "lint": "expo lint",
    "audit:data-quality": "node scripts/data-quality-audit.mjs",
    "audit:anime-relations": "node scripts/anime-relations-audit.mjs",
    "schedule-confidence": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs",
    "schedule-confidence:init": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs init",
    "schedule-confidence:reset": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs reset-local",
    "schedule-confidence:import": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs import-convex",
    "schedule-confidence:seed:fixtures": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs seed-fixtures",
    "schedule-confidence:seed:synthetic-events": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs seed-synthetic-events",
    "schedule-confidence:reconcile": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs reconcile",
    "schedule-confidence:reconcile:providers": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs reconcile --fetch-providers",
    "schedule-confidence:audit": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs audit",
    "schedule-confidence:dashboard": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs dashboard",
    "schedule-confidence:apply": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs apply-convex",
    "schedule-confidence:apply-projections": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs apply-schedule-projections",
    "schedule-confidence:compare-projections": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs compare-schedule-projections",
    "schedule-confidence:diagnose-projections": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs diagnose-projections",
    "schedule-confidence:dev:seed": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs seed-dev-cases",
    "schedule-confidence:dev:snapshot": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs snapshot-dev-cases",
    "schedule-confidence:dev:cleanup": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs cleanup-dev-cases",
    "schedule-confidence:dev:workflow": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs validate-dev-workflow --deltas .schedule-confidence/dev-convex-deltas.json --audit .schedule-confidence/dev-audit-report.json",
    "schedule-confidence:validate": "node --no-warnings=ExperimentalWarning scripts/schedule-confidence.mjs validate-fixtures",
    "test:tv-time-import": "tsx --test lib/import/tv-time-gdpr.test.ts lib/import/provider-runtime.test.ts lib/tracking/history-aggregates.test.ts",
    "ui:inspect": "node scripts/ui-inspect.mjs",
    "ui:inspect:quick": "cross-env UI_INSPECT_PRESET=quick node scripts/ui-inspect.mjs",
    "ui:inspect:headed": "cross-env PW_HEADLESS=false node scripts/ui-inspect.mjs",
    "ui:inspect:quick:headed": "cross-env UI_INSPECT_PRESET=quick PW_HEADLESS=false node scripts/ui-inspect.mjs",
    "ui:inspect:open": "npx playwright open http://localhost:8081"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@expo/vector-icons": "^15.0.3",
    "@shopify/flash-list": "2.0.2",
    "convex": "^1.14.4",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "jszip": "^3.10.1",
    "nativewind": "^4.0.36",
    "papaparse": "^5.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.10",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2"
  }
}
