{
  "name": "showtracker",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:web": "env -u CI expo start --web",
    "start:web:clear": "env -u CI expo start --web --clear",
    "start:clear": "expo start --clear",
    "lint": "expo lint",
    "ui:inspect": "node scripts/ui-inspect.mjs",
    "ui:inspect:quick": "UI_INSPECT_PRESET=quick node scripts/ui-inspect.mjs",
    "ui:inspect:headed": "PW_HEADLESS=false node scripts/ui-inspect.mjs",
    "ui:inspect:quick:headed": "UI_INSPECT_PRESET=quick PW_HEADLESS=false node scripts/ui-inspect.mjs",
    "ui:inspect:open": "npx playwright open http://localhost:8081"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.36",
    "@expo/vector-icons": "~14.0.4",
    "@shopify/flash-list": "^1.7.6",
    "convex": "^1.14.4",
    "expo": "^52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-image": "~2.0.7",
    "expo-linking": "~7.0.5",
    "expo-router": "^4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "nativewind": "^4.0.36",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
