{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "constants/**/*",
    "convex/**/*",
    "hooks/**/*",
    "lib/**/*",
    "store/**/*",
    "types/**/*"
  ]
}
